# --- AI Tech News Engine / Backend ---
# Groq API key (https://console.groq.com). Powers AI summarization + chat.
# If unset, the engine still returns a clean ranked digest via a fallback.
GROQ_API_KEY=

# Backend base URL used by the Discord bot.
API_URL=http://127.0.0.1:8000

# --- Discord Bot ---
DISCORD_TOKEN=
# Channel ID where the daily news digest is posted (right-click channel -> Copy ID).
NEWS_CHANNEL_ID=0
# UTC hour to post the daily digest (0-23).
NEWS_POST_HOUR=9
