# The Discord bot is a long-running worker and cannot run on Vercel's
# serverless platform. Exclude it (and other non-API assets) from the
# Vercel deployment bundle.
bot/

# Railway/Nixpacks-specific deploy files (not used by Vercel).
Procfile
nixpacks.toml
railway.json

