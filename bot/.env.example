# --- Discord Tech News Bot ---
# Copy this file to .env for local development (NEVER commit your real .env).

# Your Discord bot token from https://discord.com/developers/applications
# (Bot -> Reset Token). REQUIRED.
DISCORD_TOKEN=your_discord_bot_token

# Optional backend URL. Not required for the bot to work — leave blank
# unless you wire up a custom news backend.
API_URL=

# Optional: change the command prefix (default "!").
COMMAND_PREFIX=!
